<launch>
     
      <node pkg="simulation" type="JSON_param_reader" name="JSON_param_reader" output="screen"/>
      <node pkg="simulation" type="unity_TCP_stream_receiver" name="Unity_ROS_message_Rx" output="screen"/>
      <node pkg="simulation" type="ROS_command_transmitter" name="ROS_Unity_command_Tx" output="screen"/>



      <!-- define the tf tree manually -->
        <node pkg="tf" type="static_transform_publisher"
        name="tf_nominal_center"
        args="0 0 -0.7180116 0 0 0 OurCar/INS OurCar/Center 100" />

        <node pkg="tf" type="static_transform_publisher"
        name="tf_sensors"
        args="0.8199998 0 1.269 0 0 0 OurCar/Center OurCar/Sensors/SensorBase 100" />

        <node pkg="tf" type="static_transform_publisher"
        name="tf_segmentation_camera"
        args="0 0 0 0.5 -0.5 0.5 -0.5 OurCar/Sensors/SensorBase OurCar/Sensors/SemanticCamera 100" />

        <node pkg="tf" type="static_transform_publisher"
        name="tf_depth_camera"
        args="0 0 0 0.5 -0.5 0.5 -0.5 OurCar/Sensors/SensorBase OurCar/Sensors/DepthCamera 100" />

        <node pkg="tf" type="static_transform_publisher"
        name="tf_RGB_camera_left"
        args="0 0.2 0 0.5 -0.5 0.5 -0.5 OurCar/Sensors/SensorBase OurCar/Sensors/RGBCameraLeft 100" />

        <node pkg="tf" type="static_transform_publisher"
        name="tf_RGB_camera_right"
        args="0 -0.2 0 0.5 -0.5 0.5 -0.5 OurCar/Sensors/SensorBase OurCar/Sensors/RGBCameraRight 100" />

      <!-- visualize the depth cam-->
      <node pkg="nodelet" type="nodelet" name="nodelet_manager" args="manager" />
  
      <node pkg="nodelet" type="nodelet" name="depth_image_processing"
            args="load depth_image_proc/point_cloud_xyz nodelet_manager">
            <remap from="camera_info" to="/Unity_ROS_message_Rx/OurCar/Sensors/DepthCamera/camera_info"/>
            <remap from="image_rect" to="/Unity_ROS_message_Rx/OurCar/Sensors/DepthCamera/image_raw"/>
            <remap from="points" to="/perception/pcl/points"/>
      </node>

      <node pkg="octomap_server" type="octomap_server_node" name="octomap_server" output="screen">
            <remap from="cloud_in" to="/perception/pcl/points"/>
            <param name="frame_id" value="world"/>
            <param name="resolution" value="0.21"/>
            <param name="sensor_model/max_range" value="22.0"/>
            <param name="occupancy_max_z" value="2.0"/>
            <param name="publish_map" value="true"/>
            <param name="latch" value="false"/>
            <param name="use_ray_sensor" value="true"/>
            <param name="update_free_space" value="true" />
            <param name="filter_speckles" value="false"/>
            <param name="sensor_model_hit" value="0.7"/>
            <param name="sensor_model_miss" value="0.4"/>
            <param name="incremental_2D_projection" value="false"/>
            <param name="compress_map" value="false"/>
            <param name="publish_free_space" value="true"/>
            <param name="prob_hit" value="0.7"/>
            <param name="prob_miss" value="0.4"/>
            <param name="thres_min" value="0"/>
            <param name="thres_max" value="1.0"/>
            <param name="thres_occupancy" value="0.1"/>
      </node>

      <node name="traffic_light_recognition" pkg="simulation" type="traffic_light_recognition_node" output="screen" />

      <!-- launch the visualization -->
      <node pkg="rviz" type="rviz" name="rviz" args="-d $(find simulation)/rviz/visualization.rviz" />

      <node pkg="simulation" type="run_unity.sh" name="unity_sim" output="screen" />


</launch>
